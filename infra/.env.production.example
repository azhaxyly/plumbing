# ─────────────────────────────────────────────────────────────────────────────
# SINGLE SOURCE OF TRUTH for the production stack.
# Copy to infra/.env.production and fill in real values. Do NOT commit the real
# file (it is gitignored). Every container reads this file via env_file.
#
# Replace <домен> with your real domain everywhere below.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://<домен>
NEXT_PUBLIC_SITE_NAME="Timsan"

# ── Domains (consumed by Caddyfile for auto-HTTPS) ───────────────────────────
SITE_DOMAIN=<домен>
CDN_DOMAIN=cdn.<домен>

# ── Postgres (POSTGRES_* configure the postgres container; DATABASE_URL must
#    use the SAME user/password/db and host=postgres) ─────────────────────────
POSTGRES_USER=timsan
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=timsan
DATABASE_URL=postgresql://timsan:CHANGE_ME_strong_db_password@postgres:5432/timsan

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://<домен>
# generate with: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME_openssl_rand_hex_32
SESSION_TTL_DAYS=30

# ── S3 / MinIO (S3_* are also the MinIO root credentials) ────────────────────
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=https://cdn.<домен>/media
S3_REGION=us-east-1
S3_BUCKET=media
S3_ACCESS_KEY=timsan-minio
S3_SECRET_KEY=CHANGE_ME_strong_minio_password
# MinIO server picks up its root creds from these (keep equal to S3_* above):
MINIO_ROOT_USER=timsan-minio
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password

# ── Meilisearch ──────────────────────────────────────────────────────────────
MEILI_HOST=http://meilisearch:7700
# generate with: openssl rand -hex 32
MEILI_MASTER_KEY=CHANGE_ME_strong_meili_key

# ── SMTP (external provider) + owner notifications ───────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Timsan <noreply@<домен>>"
OWNER_EMAILS=owner@<домен>

# ── Shop contacts ────────────────────────────────────────────────────────────
SHOP_PHONE=+7 700 000 00 00
SHOP_EMAIL=info@<домен>

# ── Optional ─────────────────────────────────────────────────────────────────
REVALIDATION_SECRET=
# Telegram notifications (leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
# Observability
SENTRY_DSN=
