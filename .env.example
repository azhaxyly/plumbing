# === Base ===
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="My Bath Store"

# === Postgres ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whitehouse_fork

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Auth ===
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-32-bytes-random
SESSION_TTL_DAYS=30

# === S3 / MinIO ===
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/media

# === Meilisearch ===
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=dev-master-key

# === Kaspi (УТОЧНЯЕТСЯ ПРИ ОНБОРДИНГЕ У KASPI) ===
KASPI_API_BASE_URL=https://api.kaspi.example/
KASPI_MERCHANT_ID=
KASPI_API_KEY=
KASPI_WEBHOOK_SECRET=
KASPI_SIGNATURE_ALGO=HMAC-SHA256
KASPI_RETURN_URL=http://localhost:3000/checkout/success
KASPI_FAILED_URL=http://localhost:3000/checkout/failed
KASPI_WEBHOOK_URL=http://localhost:3000/api/webhooks/kaspi
KASPI_ENDPOINT_CREATE_PAYMENT=/payments
KASPI_ENDPOINT_GET_STATUS=/payments/{id}
KASPI_ENDPOINT_REFUND=/payments/{id}/refund

# === SMTP / email ===
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Магазин <noreply@example.kz>"

# === SMS (optional) ===
SMS_PROVIDER=mobizon
SMS_API_KEY=

# === Shop contacts (replace with real data!) ===
SHOP_PHONE=+7XXXXXXXXXX
SHOP_EMAIL=info@example.kz
SHOP_INSTAGRAM=@your_instagram
SHOP_LEGAL_NAME=
SHOP_BIN=
SHOP_REQUISITES_TEXT=

# === Owner notifications ===
OWNER_EMAILS=owner@example.kz,manager@example.kz
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
SMS_NOTIFY_ENABLED=false
SMS_NOTIFY_THRESHOLD_KZT=200000
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=

# === Kaspi catalog import (optional) ===
KASPI_CATALOG_FEED_URL=
KASPI_CATALOG_AUTH_HEADER=
KASPI_CATALOG_SYNC_CRON=0 */6 * * *

# === Observability (optional) ===
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# === Rate limiting ===
RATE_LIMIT_LOGIN=10/min
RATE_LIMIT_WEBHOOK=120/min

# === On-demand ISR revalidation ===
REVALIDATION_SECRET=change-me-revalidation-secret
