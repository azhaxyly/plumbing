{
  "name": "@timsan/shared",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./env": {
      "types": "./src/env.ts",
      "default": "./src/env.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:pbt": "vitest run --reporter=verbose --passWithNoTests"
  },
  "dependencies": {
    "@t3-oss/env-nextjs": "0.10.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@vitest/coverage-v8": "2.1.8",
    "fast-check": "3.23.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
