datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  customer
  manager
  admin
}

enum ProductStatus {
  active
  draft
  archived
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  phone           String?
  passwordHash    String
  role            UserRole  @default(customer)
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  blockedAt       DateTime?

  // Consent to personal data processing (Law of RK No. 94-V of 21.05.2013)
  pdnConsentAt      DateTime?
  pdnConsentVersion String? // e.g. "1.0" — matches the active privacy-policy version

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settingsUpdated Setting[]
  carts           Cart[]
  orders          Order[]
  auditLogs       AuditLog[]
  favorites       Favorite[]
}

model Category {
  id       String     @id @default(cuid())
  parentId String?
  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")

  slug          String  @unique
  name          String
  description   String?
  imageUrl      String?
  position      Int     @default(0)
  productsCount Int     @default(0)

  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductCategory[]

  @@index([slug])
  @@index([parentId])
}

model Brand {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  logoUrl       String?
  coverImageUrl String?
  description   String?
  showInGrid    Boolean  @default(false)
  gridOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products Product[]
}

model Product {
  id      String @id @default(cuid())
  slug    String @unique
  name    String
  sku     String @unique
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  shortDescription String?
  description      String?

  priceCents          Int
  compareAtPriceCents Int?

  status           ProductStatus @default(draft)
  isFeatured       Boolean       @default(false)
  defaultVariantId String?

  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants          ProductVariant[]
  images            ProductImage[]
  categories        ProductCategory[]
  productAttributes ProductAttribute[]
  favorites         Favorite[]
  bannerProducts    BannerProduct[]
  bestsellerItem    BestsellerItem?

  @@index([isFeatured])
}

model Attribute {
  id        String             @id @default(cuid())
  name      String             @unique
  slug      String             @unique
  values    AttributeValue[]
  products  ProductAttribute[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model AttributeValue {
  id          String             @id @default(cuid())
  attributeId String
  value       String
  slug        String
  attribute   Attribute          @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  products    ProductAttribute[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([attributeId, slug])
}

model ProductAttribute {
  id               String         @id @default(cuid())
  productId        String
  attributeId      String
  attributeValueId String
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute        Attribute      @relation(fields: [attributeId], references: [id])
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id])
  createdAt        DateTime       @default(now())

  @@unique([productId, attributeId])
  @@index([productId])
  @@index([attributeId])
  @@index([attributeValueId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku        String @unique
  priceCents Int
  attributes Json   @default("{}")
  quantity   Int    @default(0)
  reserved   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url       String
  alt       String  @default("")
  position  Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductCategory {
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  updatedByUserId String?
  updatedBy       User?   @relation(fields: [updatedByUserId], references: [id])
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestId   String? // UUID v4 stored in HttpOnly cookie
  items     CartItem[]
  expiresAt DateTime
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
  @@index([guestId])
}

model CartItem {
  id              String   @id @default(cuid())
  cartId          String
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId       String // reference only, no FK
  productId       String // reference only, no FK
  quantity        Int
  unitPriceCents  Int // price snapshot in tiyins at time of addition
  productName     String // snapshot
  productSku      String // snapshot
  productImageUrl String? // snapshot
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([cartId])
  @@index([variantId])
}

// ─── Order ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  new
  confirmed
  delivered
  cancelled
}

model Order {
  id      String  @id @default(cuid())
  userId  String?
  user    User?   @relation(fields: [userId], references: [id])
  guestId String? // UUID v4 для гостевых заказов

  status OrderStatus @default(new)

  // Contact info snapshot
  contactName  String
  contactPhone String
  contactEmail String? // snapshot of user.email at time of order (null for guests)

  // Delivery address snapshot
  addressStreet    String
  addressBuilding  String
  addressApartment String?
  addressCity      String  @default("Алматы")

  // Comment
  comment String?

  // Consent to personal data processing
  consentGiven Boolean   @default(false)
  consentAt    DateTime?

  // Totals snapshot
  subtotalCents Int // total in tiyins at time of order

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Snapshots at time of order (prices are frozen)
  variantId        String // reference only, not FK (variant may be deleted)
  productId        String // reference only
  nameSnapshot     String
  skuSnapshot      String
  unitPriceCents   Int // price in tiyins at time of order
  quantity         Int
  imageUrlSnapshot String?

  createdAt DateTime @default(now())

  @@index([orderId])
}

// ─── CMS Pages ────────────────────────────────────────────────────────────────

model CmsPage {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  content        String   @default("") // Markdown body
  seoTitle       String?
  seoDescription String?
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([slug])
}

// ─── Banners ──────────────────────────────────────────────────────────────────

model Banner {
  id              String    @id @default(cuid())
  title           String
  imageUrl        String
  linkUrl         String?
  backgroundColor String    @default("#f5f5f4")
  posterPosition  String    @default("left") // "left" | "right" | "none"
  maxProducts     Int       @default(4)
  position        Int       @default(0)
  isActive        Boolean   @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  products BannerProduct[]

  @@index([isActive])
  @@index([position])
}

model BannerProduct {
  id        String  @id @default(cuid())
  bannerId  String
  banner    Banner  @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  position  Int     @default(0)

  @@unique([bannerId, productId])
  @@index([bannerId])
  @@index([productId])
}

// ─── Promo Slides ─────────────────────────────────────────────────────────────

model PromoSlide {
  id        String    @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?
  position  Int       @default(0)
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive])
  @@index([position])
}

// ─── Reviews (customer testimonials slider) ──────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  authorName String
  rating     Int      @default(5)
  text       String
  position   Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
  @@index([position])
}

// ─── Bestsellers ─────────────────────────────────────────────────────────────

model BestsellerItem {
  id        String   @id @default(cuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([position])
}

// ─── Coupons ──────────────────────────────────────────────────────────────────

enum CouponType {
  percent
  fixed
}

model Coupon {
  id         String     @id @default(cuid())
  code       String     @unique
  type       CouponType
  value      Int // percent (0-100) or fixed amount in tiyins
  usageLimit Int? // null = unlimited
  usageCount Int        @default(0)
  expiresAt  DateTime?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([code])
  @@index([isActive])
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String? // null для системных действий
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String // "create" | "update" | "delete" | "status_change" | etc.
  entity      String // "Product" | "Order" | "User" | "Category" | etc.
  entityId    String
  before      Json? // состояние до изменения
  after       Json? // состояние после изменения
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}

// ─── Favorites / Wishlist ──────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}
