{
  "name": "@timsan/db",
  "version": "0.0.1",
  "private": true,
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "import-xml": "tsx prisma/import-xml.ts",
    "import-white-wave": "tsx prisma/import-white-wave.ts",
    "download-white-wave-images": "tsx prisma/download-white-wave-images.ts",
    "rename-products": "tsx prisma/rename-products.ts",
    "reindex": "tsx prisma/reindex.ts",
    "reconcile:candidates": "tsx prisma/reconcile/generate-candidates.ts",
    "reconcile:decide": "tsx prisma/reconcile/auto-decide.ts",
    "reconcile:merge": "tsx prisma/reconcile/merge-decisions.ts",
    "reconcile:apply": "tsx prisma/reconcile/apply-reconcile.ts",
    "reconcile:unmatched": "tsx prisma/reconcile/report-unmatched.ts",
    "reconcile:zero-stock": "tsx prisma/reconcile/zero-stock.ts",
    "seed:phase4": "tsx prisma/seed-phase4.ts",
    "seed:banner": "tsx prisma/seed-banner.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "argon2": "0.41.1",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
